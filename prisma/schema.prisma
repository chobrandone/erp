datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String // ADMIN, GATE_CLERK, YARD_PLANNER, PTI_INSPECTOR, FINANCE, VIEWER
  permissions  String? // JSON array of module slugs the user may access (ADMIN = all)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  gateTransactionsIn  GateTransaction[]   @relation("GateClerkIn")
  gateTransactionsOut GateTransaction[]   @relation("GateClerkOut")
  movements           ContainerMovement[]
  ptiInspections      PTIInspection[]
  auditLogs           AuditLog[]
}

model Customer {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  contactName String?
  phone       String?
  email       String?
  address     String?
  createdAt   DateTime @default(now())

  gateTransactions GateTransaction[]
  invoices         Invoice[]
  releaseOrders    ReleaseOrder[]
  ptiRequests      PTIRequest[]
}

model ShippingLine {
  id   String @id @default(cuid())
  code String @unique
  name String

  containers       Container[]
  gateTransactions GateTransaction[]
  ptiRequests      PTIRequest[]
  releaseOrders    ReleaseOrder[]
}

model ContainerType {
  id          String  @id @default(cuid())
  code        String  @unique
  description String
  lengthFt    Int
  isReefer    Boolean @default(false)

  containers Container[]
}

model Container {
  id              String        @id @default(cuid())
  containerNumber String        @unique
  containerTypeId String
  containerType   ContainerType @relation(fields: [containerTypeId], references: [id])
  shippingLineId  String?
  shippingLine    ShippingLine? @relation(fields: [shippingLineId], references: [id])
  status          String // EMPTY, FULL, DAMAGED, IN_REPAIR, BLOCKED
  isoCode         String?
  grossWeightKg   Float?
  tareWeightKg    Float?
  createdAt       DateTime      @default(now())

  inventory         Inventory?
  movements         ContainerMovement[]
  gateTransactions  GateTransaction[]
  reeferLogs        ReeferMonitoring[]
  reeferConnections ReeferConnection[]
  ptiRequests       PTIRequest[]
  repairs           Repair[]
  damageSurveys     DamageSurvey[]
  repairEstimates   RepairEstimate[]
  repairWorkOrders  RepairWorkOrder[]
  releaseOrders     ReleaseOrder[]
}

model Location {
  id           String  @id @default(cuid())
  block        String
  row          String
  bay          String
  tier         Int
  code         String  @unique
  isReeferSlot Boolean @default(false)
  maxStack     Int     @default(5)

  inventory     Inventory?
  movementsTo   ContainerMovement[] @relation("ToLocation")
  movementsFrom ContainerMovement[] @relation("FromLocation")
}

model Inventory {
  id          String    @id @default(cuid())
  containerId String    @unique
  container   Container @relation(fields: [containerId], references: [id])
  locationId  String    @unique
  location    Location  @relation(fields: [locationId], references: [id])
  enteredAt   DateTime  @default(now())
  status      String // IN_YARD, GATE_OUT, IN_TRANSIT
}

model GateTransaction {
  id             String        @id @default(cuid())
  docNumber      String        @unique
  type           String // GATE_IN, GATE_OUT
  containerId    String
  container      Container     @relation(fields: [containerId], references: [id])
  customerId     String?
  customer       Customer?     @relation(fields: [customerId], references: [id])
  shippingLineId String?
  shippingLine   ShippingLine? @relation(fields: [shippingLineId], references: [id])
  truckPlate     String
  driverName     String
  driverIdNumber String?
  sealNumber     String?
  sealNumber2    String? // N° PLOMB2 on the RTC EIR
  grossWeightKg  Float?
  destination    String? // DEST.FINALE
  releaseOrderNo String?
  condition      String        @default("GOOD") // GOOD, DAMAGED
  damageRemarks  String?
  remarks        String?
  photoUrls      String? // JSON-encoded array
  photosAttached Boolean       @default(false)
  // --- RTC / Port de Douala EIR (PROCES-VERBAL DE PRISE EN CHARGE) fields ---
  navire         String? // NAVIRE (vessel name)
  voyage         String? // VGE (voyage number)
  statut         String? // FCL / LCL
  pod            String? // Port of Discharge
  acconier       String? // ACCONIER (stevedore)
  transitaire    String? // TRANSITAIRE (freight forwarder)
  marchandise    String? // MARCHANDISE (cargo description)
  oog            Boolean       @default(false) // Out Of Gauge
  imdg           String? // IMDG dangerous-goods code
  region         String? // REGION code
  gatePost       String? // VU BST POSTE N (gate post stamp)
  tempGate       Float? // TEMP for reefer at gate
  isoCode        String? // CODE ISO (e.g. 45G1)
  documentType   String? // BL or BEE
  documentNumber String? // BL number / BEE number
  freeDays       Int? // free storage days (Free Pool) for demurrage calc
  clerkInId      String?
  clerkIn        User?         @relation("GateClerkIn", fields: [clerkInId], references: [id])
  clerkOutId     String?
  clerkOut       User?         @relation("GateClerkOut", fields: [clerkOutId], references: [id])
  status         String        @default("COMPLETED")
  createdAt      DateTime      @default(now())
}

model ContainerMovement {
  id             String    @id @default(cuid())
  docNumber      String    @unique
  containerId    String
  container      Container @relation(fields: [containerId], references: [id])
  fromLocationId String?
  fromLocation   Location? @relation("FromLocation", fields: [fromLocationId], references: [id])
  toLocationId   String
  toLocation     Location  @relation("ToLocation", fields: [toLocationId], references: [id])
  reason         String // YARD_ALLOCATION, YARD_REPOSITION, PTI, REEFER_CONNECTION, REPAIR, GATE_OUT
  equipment      String?
  operator       String?
  movedById      String?
  movedBy        User?     @relation(fields: [movedById], references: [id])
  supervisorName String?
  completed      Boolean   @default(false)
  completionTime DateTime?
  remarks        String?
  createdAt      DateTime  @default(now())
}

model ReeferMonitoring {
  id               String    @id @default(cuid())
  reportNo         String?   @unique
  containerId      String
  container        Container @relation(fields: [containerId], references: [id])
  plugNumber       String?
  setTempC         Float
  actualTempC      Float
  supplyAirTempC   Float?
  returnAirTempC   Float?
  ambientTempC     Float?
  humidity         Float?
  powerStatus      String // CONNECTED, DISCONNECTED, ALARM
  alarmStatus      String    @default("NORMAL") // NORMAL, ALARM
  alarmDescription String?
  technician       String?
  remarks          String?
  recordedAt       DateTime  @default(now())
}

model ReeferConnection {
  id                String    @id @default(cuid())
  referenceNo       String    @unique
  containerId       String
  container         Container @relation(fields: [containerId], references: [id])
  plugNumber        String?
  connectionTime    DateTime?
  disconnectionTime DateTime?
  connectedBy       String?
  disconnectedBy    String?
  powerStatus       String    @default("OPERATIONAL") // OPERATIONAL, FAULT
  remarks           String?
  createdAt         DateTime  @default(now())
}

model PTIRequest {
  id             String        @id @default(cuid())
  docNumber      String        @unique
  containerId    String
  container      Container     @relation(fields: [containerId], references: [id])
  customerId     String?
  customer       Customer?     @relation(fields: [customerId], references: [id])
  shippingLineId String?
  shippingLine   ShippingLine? @relation(fields: [shippingLineId], references: [id])
  priority       String        @default("NORMAL")
  status         String        @default("PENDING") // PENDING, IN_PROGRESS, PASSED, FAILED
  requiredDate   DateTime?
  inspectionType String        @default("STANDARD") // STANDARD, SPECIAL
  remarks        String?
  requestedBy    String?
  approvedBy     String?
  requestedAt    DateTime      @default(now())

  inspection PTIInspection?
}

model PTIInspection {
  id                String     @id @default(cuid())
  ptiRequestId      String     @unique
  ptiRequest        PTIRequest @relation(fields: [ptiRequestId], references: [id])
  inspectorId       String?
  inspector         User?      @relation(fields: [inspectorId], references: [id])
  certificateNumber String?    @unique
  checklistJson     String // JSON-encoded checklist results
  result            String // PASS, FAIL
  remarks           String?
  inspectedAt       DateTime   @default(now())
}

model Repair {
  id                   String    @id @default(cuid())
  containerId          String
  container            Container @relation(fields: [containerId], references: [id])
  component            String? // ROOF, LEFT_SIDE, DOOR, FLOOR, ...
  damageType           String // DENT, HOLE, CRACK, ...
  severity             String? // MINOR, MODERATE, MAJOR
  repairMethod         String? // WELD, PATCH, STRAIGHTEN, ...
  repairResponsibility String? // CARRIER, CUSTOMER, DEPOT, SURVEYOR
  description          String?
  estimatedCost        Float?
  status               String    @default("PENDING") // PENDING, APPROVED, REPAIRED, REJECTED, NOT_REPAIRABLE
  createdAt            DateTime  @default(now())
}

model Document {
  id        String   @id @default(cuid())
  type      String // GATE_IN_EIR, GATE_OUT_EIR, MOVEMENT_ORDER, PTI_CERTIFICATE, INVOICE
  refId     String
  filePath  String
  createdAt DateTime @default(now())
}

model DamageSurvey {
  id                String    @id @default(cuid())
  surveyNo          String    @unique
  containerId       String
  container         Container @relation(fields: [containerId], references: [id])
  location          String?
  surveyDate        DateTime  @default(now())
  surveyor          String?
  frontEnd          String?
  rearEnd           String?
  roof              String?
  floor             String?
  leftSide          String?
  rightSide         String?
  severity          String    @default("MINOR") // MINOR, MODERATE, MAJOR
  photosAttached    Boolean   @default(false)
  repairRecommended Boolean   @default(false)
  remarks           String?
  createdAt         DateTime  @default(now())
}

model RepairEstimate {
  id               String    @id @default(cuid())
  estimateNo       String    @unique
  containerId      String
  container        Container @relation(fields: [containerId], references: [id])
  workDescription  String
  laborCost        Float     @default(0)
  materialCost     Float     @default(0)
  equipmentCost    Float     @default(0)
  customerApproved Boolean   @default(false)
  approvalDate     DateTime?
  remarks          String?
  createdAt        DateTime  @default(now())
}

model RepairWorkOrder {
  id                 String    @id @default(cuid())
  workOrderNo        String    @unique
  containerId        String
  container          Container @relation(fields: [containerId], references: [id])
  assignedTechnician String?
  startDate          DateTime?
  expectedCompletion DateTime?
  workToBeDone       String
  materialsRequired  String?
  completionStatus   String    @default("OPEN") // OPEN, IN_PROGRESS, COMPLETED
  remarks            String?
  createdAt          DateTime  @default(now())
}

model ReleaseOrder {
  id                    String        @id @default(cuid())
  releaseNo             String        @unique
  containerId           String
  container             Container     @relation(fields: [containerId], references: [id])
  customerId            String?
  customer              Customer?     @relation(fields: [customerId], references: [id])
  shippingLineId        String?
  shippingLine          ShippingLine? @relation(fields: [shippingLineId], references: [id])
  authorizedReleaseDate DateTime?
  destination           String?
  approvedBy            String?
  gateAuthorization     String        @default("APPROVED") // APPROVED, REJECTED
  remarks               String?
  createdAt             DateTime      @default(now())
}

model Invoice {
  id                String    @id @default(cuid())
  invoiceNumber     String    @unique
  customerId        String
  customer          Customer  @relation(fields: [customerId], references: [id])
  description       String?
  currency          String    @default("XAF")
  subtotal          Float     @default(0) // Montant HT
  tvaRate           Float     @default(19.25) // Cameroon TVA %
  tvaAmount         Float     @default(0)
  amount            Float // Montant TTC
  paymentMethod     String? // Espèces, Virement, Mobile Money, BICEC, Autre
  status            String    @default("UNPAID")
  issuedAt          DateTime  @default(now())
  dueAt             DateTime?
  paidAt            DateTime?
  // Payment receipt — required to mark an invoice PAID.
  receiptData       Bytes?
  receiptMime       String?
  receiptName       String?
  receiptVerified   Boolean   @default(false) // passed the "is this a receipt?" heuristic
  receiptUploadedAt DateTime?
  // Soft-delete / sandbox — financial records are never hard-deleted by staff.
  archived          Boolean   @default(false)
  voidedAt          DateTime?
  voidedBy          String? // name/email of the user who voided it
  voidReason        String?

  lines InvoiceLine[]
}

model InvoiceLine {
  id              String  @id @default(cuid())
  invoiceId       String
  invoice         Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description     String
  quantity        Float   @default(1)
  unitPrice       Float   @default(0)
  lineTotal       Float   @default(0)
  containerNumber String?
}

// Tariff table (XAF) — seeded from the client's Depot & Truck Transport Service Contract.
model BillingRate {
  id       String  @id @default(cuid())
  code     String  @unique // e.g. STORAGE_EMPTY_20, LOLO_40, WASH_20, PTI_SHORT_20
  service  String // human-readable service name
  category String // STORAGE, LOLO, WASHING, CLEANING, PTI, TRUCKING, FOOD_GRADE, OTHER
  size     String? // 20, 40
  isReefer Boolean @default(false)
  unit     String  @default("unit") // unit, teu_day
  rateXaf  Float
  active   Boolean @default(true)
}

model Vehicle {
  id                String   @id @default(cuid())
  plateNumber       String   @unique
  make              String?
  model             String?
  type              String   @default("TRUCK") // TRUCK, TRAILER
  capacityTeu       Int?
  driverName        String?
  driverPhone       String?
  status            String   @default("ACTIVE") // ACTIVE, MAINTENANCE, INACTIVE
  // Operational state: IN_PARK (available in yard) | IN_USE (on a trip) | MAINTENANCE
  operationalStatus String   @default("IN_PARK")
  odometerKm        Int?
  createdAt         DateTime @default(now())

  documents VehicleDocument[]
  trips     VehicleTrip[]
}

model VehicleTrip {
  id               String    @id @default(cuid())
  tripNo           String    @unique
  vehicleId        String
  vehicle          Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driverName       String
  driverPhone      String?
  cargoType        String    @default("CONTAINER") // CONTAINER, EQUIPMENT, GOODS, EMPTY
  containerNumber  String? // the container / equipment carried
  cargoDescription String?
  origin           String?
  destination      String
  departureTime    DateTime  @default(now())
  expectedReturn   DateTime?
  returnTime       DateTime?
  status           String    @default("ONGOING") // ONGOING, COMPLETED, CANCELLED
  remarks          String?
  createdAt        DateTime  @default(now())
}

model VehicleDocument {
  id         String    @id @default(cuid())
  vehicleId  String
  vehicle    Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  docType    String // DRIVER_LICENSE, INSURANCE, TECHNICAL_INSPECTION, CARTE_GRISE, VIGNETTE
  reference  String?
  issuedDate DateTime?
  expiryDate DateTime
  remarks    String?
  createdAt  DateTime  @default(now())
}

model Equipment {
  id     String @id @default(cuid())
  code   String @unique
  type   String // RTG, REACH_STACKER, FORKLIFT, TRUCK
  status String @default("AVAILABLE")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String
  metaJson  String?
  createdAt DateTime @default(now())
}
